{
  "name": "comanda-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/prisma/seed.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "test": "jest --runInBand",
    "migrate:prod": "prisma migrate deploy",
    "setup:prod": "npm run prisma:generate && npm run migrate:prod && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prisma": "^5.15.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
