generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("administrador")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
}

model Bracelet {
  id        String    @id @default(uuid())
  number    String    @unique
  type      String    @default("QR")
  status    String    @default("livre")
  blockedReason String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comandas  Comanda[]
}

model Comanda {
  id               String        @id @default(uuid())
  bracelet         Bracelet      @relation(fields: [braceletId], references: [id])
  braceletId       String
  client           Client?       @relation(fields: [clientId], references: [id])
  clientId         String?
  event            Event?        @relation(fields: [eventId], references: [id])
  eventId          String?
  status           String        @default("aberta")
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  total            Decimal       @default("0")
  clienteNome      String        @default("")
  clienteCpf       String        @default("")
  clienteTelefone  String        @default("")
  clienteEmail     String        @default("")
  clienteNascimento DateTime?
  pedidos          Pedido[]
}

model Pedido {
  id           String   @id @default(uuid())
  comanda      Comanda  @relation(fields: [comandaId], references: [id])
  comandaId    String
  produto      Produto? @relation(fields: [produtoId], references: [id])
  produtoId    String?
  nome         String
  quantidade   Int
  valorUnitario Decimal
  subtotal     Decimal
  cancelado    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Produto {
  id        String   @id @default(uuid())
  nome      String
  preco     Decimal
  categoria String
  ativo     Boolean  @default(true)
  estoque   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pedidos   Pedido[]
  stockMovements StockMovement[]
}

model Client {
  id              String    @id @default(uuid())
  name            String
  cpf             String    @unique
  phone           String
  email           String?
  birthDate       DateTime?
  blocked         Boolean   @default(false)
  notes           String?
  loyaltyPoints   Int       @default(0)
  cashbackBalance Decimal   @default("0")
  tier            String    @default("Bronze")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comandas        Comanda[]
}

model Event {
  id          String    @id @default(uuid())
  name        String
  description String?
  location    String?
  capacity    Int       @default(0)
  status      String    @default("planejado")
  startAt     DateTime?
  endAt       DateTime?
  checkIns    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comandas    Comanda[]
}

model CashMovement {
  id          String   @id @default(uuid())
  type        String
  amount      Decimal
  description String
  createdAt   DateTime @default(now())
}

model StockMovement {
  id            String   @id @default(uuid())
  produto       Produto  @relation(fields: [produtoId], references: [id])
  produtoId     String
  type          String
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  String?
  ip        String?
  device    String?
  createdAt DateTime @default(now())
}

model DeviceSession {
  id          String   @id @default(uuid())
  name        String?
  socketId    String?
  ip          String?
  role        String   @default("garcom")
  status      String   @default("ativo")
  pairingCode String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackupRecord {
  id        String   @id @default(uuid())
  filename  String
  path      String
  size      Int
  createdAt DateTime @default(now())
}
